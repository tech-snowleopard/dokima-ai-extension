{
  "manifest_version": 3,
  "name": "Dokima AI",
  "version": "0.3.33",
  "description": "AI-powered, pre-built scoring to drive consistent sales playbook execution",
  "permissions": [
    "activeTab",
    "storage",
    "identity"
  ],
  "host_permissions": [
    "*://app.fireflies.ai/*",
    "*://app.modjo.ai/*",
    "*://app.clari.com/*",
    "*://*.app.gong.io/*",
    "*://app.gong.io/*",
    "*://dashboard.aircall.io/*",
    "http://localhost:3000/*",
    "https://app.dokima.ai/*",
    "https://api.dokima.ai/*"
  ],
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/modjo-network-interceptor-v2.ts-DtiEQFRF.js"
      ],
      "matches": [
        "*://app.modjo.ai/*"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "js": [
        "assets/modjo-ui-automation.ts-CI6QS0Vw.js"
      ],
      "matches": [
        "*://app.modjo.ai/call/*",
        "*://app.modjo.ai/call-details/*",
        "*://app.modjo.ai/deals/*/call/*"
      ],
      "run_at": "document_end",
      "world": "MAIN"
    },
    {
      "js": [
        "assets/ui-manager.ts-loader-DJRV-wHX.js",
        "assets/platform-scraper.ts-loader-C0tpbSqy.js"
      ],
      "matches": [
        "*://app.fireflies.ai/*",
        "*://app.modjo.ai/*",
        "*://app.clari.com/*",
        "*://*.app.gong.io/*",
        "*://app.gong.io/*",
        "*://dashboard.aircall.io/*"
      ],
      "css": [
        "content-scripts/ui-styles.css"
      ],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Dokima AI"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "side_panel": {
    "default_path": "sidepanel/index.html"
  },
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "sidepanel/*",
        "assets/*",
        "onboarding/onboarding.html"
      ],
      "use_dynamic_url": false
    },
    {
      "matches": [
        "*://app.modjo.ai/*"
      ],
      "resources": [
        "assets/modjo-network-interceptor-v2.ts-DtiEQFRF.js"
      ],
      "use_dynamic_url": false
    },
    {
      "matches": [
        "*://app.modjo.ai/*",
        "*://app.modjo.ai/*",
        "*://app.modjo.ai/*"
      ],
      "resources": [
        "assets/modjo-ui-automation.ts-CI6QS0Vw.js"
      ],
      "use_dynamic_url": false
    },
    {
      "matches": [
        "*://*.app.gong.io/*",
        "*://app.clari.com/*",
        "*://app.fireflies.ai/*",
        "*://app.gong.io/*",
        "*://app.modjo.ai/*",
        "*://dashboard.aircall.io/*"
      ],
      "resources": [
        "assets/constants-BZlHI6XL.js",
        "assets/platform-scraper-Dj2gyeFJ.js",
        "assets/cache-service-CzSbCUsz.js",
        "assets/platform-scraper.ts-CZhMVc6d.js",
        "assets/ui-manager.ts-giAQviBO.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
