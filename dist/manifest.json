{
  "manifest_version": 3,
  "name": "Dokima AI",
  "version": "0.3.31",
  "description": "AI-powered, pre-built scoring to drive consistent sales playbook execution",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "*://app.fireflies.ai/*",
    "*://app.modjo.ai/*",
    "*://app.clari.com/*",
    "*://app.gong.io/*",
    "*://dashboard.aircall.io/*",
    "http://localhost:3000/*",
    "https://tech-snowleopard-callscore-extensio.vercel.app/*",
    "https://callscore-extension-production.up.railway.app/*"
  ],
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/modjo-network-interceptor-v2.ts-BCq0Agp5.js"
      ],
      "matches": [
        "*://app.modjo.ai/*"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "js": [
        "assets/modjo-ui-automation.ts-CI6QS0Vw.js"
      ],
      "matches": [
        "*://app.modjo.ai/call/*",
        "*://app.modjo.ai/call-details/*",
        "*://app.modjo.ai/deals/*/call/*"
      ],
      "run_at": "document_end",
      "world": "MAIN"
    },
    {
      "js": [
        "assets/ui-manager.ts-loader-8ZVCnXLJ.js",
        "assets/platform-scraper.ts-loader-C4oGE65i.js"
      ],
      "matches": [
        "*://app.fireflies.ai/*",
        "*://app.modjo.ai/*",
        "*://app.clari.com/*",
        "*://app.gong.io/*",
        "*://dashboard.aircall.io/*"
      ],
      "css": [
        "content-scripts/ui-styles.css"
      ],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "SalesAgents AI"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "side_panel": {
    "default_path": "sidepanel/index.html"
  },
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "sidepanel/*",
        "assets/*"
      ],
      "use_dynamic_url": false
    },
    {
      "matches": [
        "*://app.modjo.ai/*"
      ],
      "resources": [
        "assets/modjo-network-interceptor-v2.ts-BCq0Agp5.js"
      ],
      "use_dynamic_url": false
    },
    {
      "matches": [
        "*://app.modjo.ai/*",
        "*://app.modjo.ai/*",
        "*://app.modjo.ai/*"
      ],
      "resources": [
        "assets/modjo-ui-automation.ts-CI6QS0Vw.js"
      ],
      "use_dynamic_url": false
    },
    {
      "matches": [
        "*://app.clari.com/*",
        "*://app.fireflies.ai/*",
        "*://app.gong.io/*",
        "*://app.modjo.ai/*",
        "*://dashboard.aircall.io/*"
      ],
      "resources": [
        "assets/constants-BFj5qgTA.js",
        "assets/platform-scraper.ts-BLdOwZys.js",
        "assets/cache-service-CzSbCUsz.js",
        "assets/ui-manager.ts-Tb0yB0r5.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
